{
  "name": "school-dbms",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001 --webpack -H 127.0.0.1",
    "dev:turbo": "next dev -p 3001 -H 127.0.0.1",
    "stop-dev": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/stop-dev.ps1",
    "clean": "node -e \"try{require('fs').rmSync('.next',{recursive:true,force:true})}catch(e){}\"",
    "dev:clean": "npm run stop-dev && npm run clean && npm run dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "import-students": "node scripts/import-students.mjs",
    "migrate-users": "node scripts/migrate-users.mjs",
    "create-admin": "node scripts/create-admin.mjs",
    "clear-data": "node scripts/clear-all-data.mjs",
    "setup-pins": "node scripts/setup-quick-pins.mjs",
    "prepare-vercel-env": "node scripts/prepare-vercel-admin-env.mjs",
    "push-vercel-env": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/push-vercel-admin-env.ps1",
    "generate-pwa-icons": "node scripts/generate-pwa-icons.mjs",
    "generate-android-twa": "node scripts/generate-android-twa.mjs",
    "sync-android-icons": "node scripts/sync-android-launcher-icons.mjs",
    "generate-android-splash": "node scripts/generate-android-splash.mjs",
    "icons:all": "npm run generate-pwa-icons && npm run generate-android-twa && npm run sync-android-icons && npm run generate-android-splash"
  },
  "dependencies": {
